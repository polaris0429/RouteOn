<resources>
    <style name="Theme.RouteOn" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorPrimaryVariant">#1B5E20</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">@color/brand_green_light</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:windowBackground">@color/bg_page</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- bar 색상·아이콘은 코드(applySystemBarsColor)에서만 제어 -->
        <!-- 단, 네비게이션바는 테마에서도 black으로 고정하여 코드 적용 전 깜빡임 방지 -->
        <item name="android:navigationBarColor">#FF000000</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="ToolbarTitleStyle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">17sp</item>
        <item name="android:textColor">@color/toolbar_title</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
