<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center"
    android:background="#FEE500">

    <ImageView
        android:layout_width="319dp"
        android:layout_height="74dp"
        android:layout_marginBottom="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/routeon_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="루트온 기사 로그인"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/et_username"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="아이디 (Username)"
        android:inputType="text"
        android:padding="15dp"
        android:background="@drawable/bg_rounded_input"
        android:textColorHint="#888888"
        android:layout_marginBottom="15dp"
        android:textColor="#000000" />

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_rounded_input"
        android:hint="비밀번호"
        android:inputType="textPassword"
        android:padding="15dp"
        android:textColor="#000000"
        android:textColorHint="#888888" />

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="로그인"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#03C75A"
        app:cornerRadius="12dp"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_go_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="계정이 없으신가요? 회원가입하기"
        android:textSize="15sp"
        android:textColor="#333333"
        android:textStyle="bold"
        android:padding="10dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>