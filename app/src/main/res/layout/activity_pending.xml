<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="40dp"
    android:background="#FEE500">

    <ImageView
        android:layout_width="240dp"
        android:layout_height="120dp"
        android:layout_marginBottom="30dp"
        android:scaleType="fitCenter"
        android:contentDescription="앱 로고"
        android:src="@drawable/routeon_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="승인 대기 중입니다."
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:textAlignment="center"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="관리자 승인 후\n정식으로 이용하실 수 있습니다.\n업체 관리자에게 문의해 주세요."
        android:textSize="16sp"
        android:textColor="#444444"
        android:textAlignment="center"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btn_back_to_login"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="로그인 화면으로 돌아가기"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#03C75A"
        app:cornerRadius="12dp" />

</LinearLayout>