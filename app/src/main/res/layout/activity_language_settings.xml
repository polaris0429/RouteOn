<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F3F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="언어"
        app:titleTextAppearance="@style/ToolbarTitleStyle"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F2F3F5"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="앱 언어"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp"/>

                    <!-- 한국어 -->
                    <LinearLayout android:id="@+id/langKorean"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="20dp"
                        android:background="@drawable/ripple_white" android:clickable="true" android:focusable="true">
                        <RadioButton android:id="@+id/radioKorean"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:checked="true" android:buttonTint="#FFEB00"
                            android:clickable="false" android:focusable="false"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="한국어"
                            android:textSize="15sp" android:textColor="#1A1A1A" android:layout_marginStart="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Korean" android:textSize="13sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="52dp" android:background="#E5E5E5"/>

                    <!-- 영어 -->
                    <LinearLayout android:id="@+id/langEnglish"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="20dp"
                        android:background="@drawable/ripple_white" android:clickable="true" android:focusable="true">
                        <RadioButton android:id="@+id/radioEnglish"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:buttonTint="#FFEB00" android:clickable="false" android:focusable="false"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="English"
                            android:textSize="15sp" android:textColor="#1A1A1A" android:layout_marginStart="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="영어" android:textSize="13sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="52dp" android:background="#E5E5E5"/>

                    <!-- 일본어 -->
                    <LinearLayout android:id="@+id/langJapanese"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="20dp"
                        android:background="@drawable/ripple_white" android:clickable="true" android:focusable="true">
                        <RadioButton android:id="@+id/radioJapanese"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:buttonTint="#FFEB00" android:clickable="false" android:focusable="false"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="日本語"
                            android:textSize="15sp" android:textColor="#1A1A1A" android:layout_marginStart="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="일본어" android:textSize="13sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="52dp" android:background="#E5E5E5"/>

                    <!-- 중국어 -->
                    <LinearLayout android:id="@+id/langChinese"
                        android:layout_width="match_parent" android:layout_height="56dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingStart="20dp" android:paddingEnd="20dp"
                        android:background="@drawable/ripple_white" android:clickable="true" android:focusable="true">
                        <RadioButton android:id="@+id/radioChinese"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:buttonTint="#FFEB00" android:clickable="false" android:focusable="false"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="中文 (简体)"
                            android:textSize="15sp" android:textColor="#1A1A1A" android:layout_marginStart="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="중국어" android:textSize="13sp" android:textColor="#AAAAAA"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
