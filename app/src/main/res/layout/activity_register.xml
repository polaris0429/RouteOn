<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:gravity="center"
    android:background="#FEE500">

    <ImageView
        android:layout_width="305dp"
        android:layout_height="76dp"
        android:layout_marginBottom="16dp"
        android:scaleType="fitCenter"
        android:src="@drawable/routeon_logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="기사님 환영합니다!"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:layout_marginBottom="30dp"/>

    <EditText android:id="@+id/et_org_code" android:layout_width="match_parent" android:layout_height="55dp" android:hint="조직코드 (예: RT-XXXXXX)" android:inputType="textCapCharacters" android:padding="15dp" android:background="@drawable/bg_rounded_input" android:textColorHint="#888888" android:layout_marginBottom="15dp" android:textColor="#000000" />
    <EditText android:id="@+id/et_username" android:layout_width="match_parent" android:layout_height="55dp" android:hint="로그인 아이디 (Username)" android:inputType="text" android:padding="15dp" android:background="@drawable/bg_rounded_input" android:textColorHint="#888888" android:layout_marginBottom="15dp" android:textColor="#000000" />
    <EditText android:id="@+id/et_password" android:layout_width="match_parent" android:layout_height="55dp" android:hint="비밀번호" android:inputType="textPassword" android:padding="15dp" android:background="@drawable/bg_rounded_input" android:textColorHint="#888888" android:layout_marginBottom="15dp" android:textColor="#000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp">

        <EditText
            android:id="@+id/et_phone"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:hint="휴대전화 번호 (- 제외)"
            android:inputType="phone"
            android:padding="15dp"
            android:background="@drawable/bg_rounded_input"
            android:textColorHint="#888888"
            android:textColor="#000000" />

        <Button
            android:id="@+id/btn_send_sms"
            android:layout_width="100dp"
            android:layout_height="55dp"
            android:layout_marginStart="10dp"
            android:text="인증요청"
            android:backgroundTint="#03C75A"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            app:cornerRadius="12dp" /> </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_verification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="30dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="15dp">

            <EditText android:id="@+id/otp1" android:layout_width="45dp" android:layout_height="55dp" android:background="@drawable/bg_rounded_input" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"/>
            <EditText android:id="@+id/otp2" android:layout_width="45dp" android:layout_height="55dp" android:layout_marginStart="8dp" android:background="@drawable/bg_rounded_input" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"/>
            <EditText android:id="@+id/otp3" android:layout_width="45dp" android:layout_height="55dp" android:layout_marginStart="8dp" android:background="@drawable/bg_rounded_input" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"/>
            <EditText android:id="@+id/otp4" android:layout_width="45dp" android:layout_height="55dp" android:layout_marginStart="8dp" android:background="@drawable/bg_rounded_input" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"/>
            <EditText android:id="@+id/otp5" android:layout_width="45dp" android:layout_height="55dp" android:layout_marginStart="8dp" android:background="@drawable/bg_rounded_input" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"/>
            <EditText android:id="@+id/otp6" android:layout_width="45dp" android:layout_height="55dp" android:layout_marginStart="8dp" android:background="@drawable/bg_rounded_input" android:gravity="center" android:inputType="number" android:maxLength="1" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold"/>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btn_verify_sms"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="인증확인"
                android:backgroundTint="#03C75A"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="12dp" />

            <TextView
                android:id="@+id/tv_verify_success"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="✅ 인증되었습니다."
                android:textColor="#03C75A"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center"
                android:visibility="gone"
                android:background="@drawable/bg_rounded_input" />
        </FrameLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btn_register"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="회원가입 완료"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#03C75A"
        app:cornerRadius="12dp" />

</LinearLayout>