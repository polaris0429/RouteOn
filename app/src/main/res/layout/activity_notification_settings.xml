<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F3F5">

    <!-- 툴바 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="알림"
        app:titleTextAppearance="@style/ToolbarTitleStyle"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F2F3F5"/>

            <!-- 알림 설정 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF">

                    <!-- 섹션 헤더 -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="알림 허용"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp"/>

                    <!-- 앱 알림 전체 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="앱 알림"
                                android:textSize="15sp"
                                android:textColor="#1A1A1A"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="내비게이션 관련 알림을 모두 받습니다"
                                android:textSize="12sp"
                                android:textColor="#888888"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchAppNotification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="#FFEB00"
                            android:trackTint="#FFEB0066"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="20dp" android:background="#E5E5E5"/>

                    <!-- 교통 정보 알림 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="교통 정보 알림"
                                android:textSize="15sp"
                                android:textColor="#1A1A1A"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="사고, 공사, 정체 구간 알림"
                                android:textSize="12sp"
                                android:textColor="#888888"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchTrafficNotification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="#FFEB00"
                            android:trackTint="#FFEB0066"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="20dp" android:background="#E5E5E5"/>

                    <!-- 과속 카메라 알림 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="과속 카메라 알림"
                                android:textSize="15sp"
                                android:textColor="#1A1A1A"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="단속 카메라 구간 사전 안내"
                                android:textSize="12sp"
                                android:textColor="#888888"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchSpeedCamera"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="#FFEB00"
                            android:trackTint="#FFEB0066"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="20dp" android:background="#E5E5E5"/>

                    <!-- 음성 안내 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="음성 안내 음량"
                                    android:textSize="15sp"
                                    android:textColor="#1A1A1A"/>

                                <TextView
                                    android:id="@+id/tvVolumeValue"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="100%"
                                    android:textSize="12sp"
                                    android:textColor="#3A86FF"
                                    android:layout_marginTop="2dp"/>
                            </LinearLayout>

                            <Switch
                                android:id="@+id/switchVoiceGuide"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checked="true"
                                android:thumbTint="#FFEB00"
                                android:trackTint="#FFEB0066"/>

                        </LinearLayout>

                        <!-- 볼륨 슬라이더 -->
                        <SeekBar
                            android:id="@+id/seekbarVolume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:max="100"
                            android:progress="100"
                            android:progressTint="#FFEB00"
                            android:thumbTint="#FFEB00"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0%" android:textSize="11sp" android:textColor="#AAAAAA"/>
                            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="100%" android:textSize="11sp" android:textColor="#AAAAAA"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
