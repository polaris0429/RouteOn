<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F3F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:title="화면 테마 · 진동"
        app:titleTextAppearance="@style/ToolbarTitleStyle"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F2F3F5"/>

            <!-- 화면 모드 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="화면 모드"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="16dp"
                        android:weightSum="2">

                        <!-- 주간 모드 -->
                        <LinearLayout
                            android:id="@+id/optionDayMode"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/theme_option_selected"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="☀️" android:textSize="28sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="주간 모드" android:textSize="14sp"
                                android:textColor="#1A1A1A" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                        <!-- 야간 모드 -->
                        <LinearLayout
                            android:id="@+id/optionNightMode"
                            android:layout_width="0dp"
                            android:layout_height="100dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/theme_option_unselected"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🌙" android:textSize="28sp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="야간 모드" android:textSize="14sp"
                                android:textColor="#1A1A1A" android:layout_marginTop="6dp"/>
                        </LinearLayout>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:background="#E5E5E5"/>

                    <!-- 자동 밝기 조절 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="시스템 설정 따라가기" android:textSize="15sp" android:textColor="#1A1A1A"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="기기의 다크모드 설정을 자동으로 반영"
                                android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchAutoBrightness"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:thumbTint="#4CAF50"
                            android:trackTint="#4CAF5066"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="8dp" android:background="#F2F3F5"/>

            <!-- 진동 카드 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#FFFFFF">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="진동"
                        android:textSize="12sp"
                        android:textColor="#888888"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="8dp"/>

                    <!-- 안내 진동 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="안내 진동" android:textSize="15sp" android:textColor="#1A1A1A"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="음성 안내 시 진동으로 알림"
                                android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchVibration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            android:thumbTint="#4CAF50"
                            android:trackTint="#4CAF5066"/>

                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="0.5dp"
                        android:layout_marginStart="20dp" android:background="#E5E5E5"/>

                    <!-- 터치 햅틱 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="터치 햅틱" android:textSize="15sp" android:textColor="#1A1A1A"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="버튼 터치 시 진동 피드백"
                                android:textSize="12sp" android:textColor="#888888" android:layout_marginTop="2dp"/>
                        </LinearLayout>

                        <Switch
                            android:id="@+id/switchHaptic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:thumbTint="#4CAF50"
                            android:trackTint="#4CAF5066"/>

                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="24dp"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
